#!/usr/bin/env zsh
# Headless variant of ai-task-start-kanban — no cmux, runs tasks in parallel
# subprocesses with a live CLI dashboard.
#
# Usage:
#   ai-task-start-kanban-headless                        # uses <project>-kanban/issues/ (all .active.md + .backlog.md)
#   ai-task-start-kanban-headless <issues-folder>        # explicit path
#   ai-task-start-kanban-headless --watch                # watch for new .backlog.md issues
#   ai-task-start-kanban-headless --watch --poll-seconds 10
#   ai-task-start-kanban-headless --log-preview-lines 10 # show N last lines of current task's log below table
#
# If no argument given, resolves the kanban repo from the current project root.

WATCH_FLAG=""
POSITIONAL_ARGS=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --watch|-w)
      WATCH_FLAG="--watch"
      shift
      ;;
    --poll-seconds)
      POLL_SECONDS="$2"
      shift 2
      ;;
    --log-preview-lines)
      LOG_PREVIEW_LINES="$2"
      shift 2
      ;;
    *)
      POSITIONAL_ARGS+=("$1")
      shift
      ;;
  esac
done

if [[ -n "${POSITIONAL_ARGS[1]:-}" ]]; then
  issues_dir="${POSITIONAL_ARGS[1]}"
else
  project_dir="$(git rev-parse --show-toplevel 2>/dev/null || echo "$PWD")"
  project_dir="$(cd "$project_dir" && pwd)"
  issues_dir="$(dirname "$project_dir")/$(basename "$project_dir")-kanban/issues"
fi

issues_dir="$(cd "$issues_dir" 2>/dev/null && pwd)" || {
  echo "[kanban] error: issues directory not found: $issues_dir" >&2
  echo "[kanban] tip: run init-kanban-repo first, or pass the issues path explicitly." >&2
  exit 1
}

project_name="$(basename "$(dirname "$(dirname "$issues_dir")")")"
project_dir="$PWD"
status_dir="/tmp/kanban-${project_name}-$$"
mkdir -p "$status_dir"

python3 ~/projects/renan/agent-tools/scripts/kanban-parse-deps.py "$issues_dir" \
  > "${status_dir}/deps.json"
echo "[kanban] deps parsed → ${status_dir}/deps.json"

export KANBAN_MODEL="${KANBAN_MODEL:-sonnet}"
export KANBAN_HEADLESS=1

if ! python3 -c "import rich" 2>/dev/null; then
  echo "[kanban] tip: pip install --user rich  → enables the rich live dashboard (plain mode for now)"
fi

ORCHESTRATOR="$HOME/projects/renan/agent-tools/scripts/kanban-orchestrator-headless.py"
ORCHESTRATOR_ARGS=()
[[ -n "$WATCH_FLAG" ]] && ORCHESTRATOR_ARGS+=("$WATCH_FLAG")
[[ -n "${POLL_SECONDS:-}" ]] && ORCHESTRATOR_ARGS+=(--poll-seconds "$POLL_SECONDS")
[[ -n "${LOG_PREVIEW_LINES:-}" ]] && ORCHESTRATOR_ARGS+=(--log-preview-lines "$LOG_PREVIEW_LINES")
ORCHESTRATOR_ARGS+=("$issues_dir" "$project_dir" "$status_dir")

exec python3 "$ORCHESTRATOR" "${ORCHESTRATOR_ARGS[@]}"
