#!/usr/bin/env zsh
# Start kanban tasks using cmux tabs, reading issues from the kanban repo.
#
# Usage:
#   ai-task-start-kanban                               # uses <project>-kanban/issues/
#   ai-task-start-kanban <issues-folder>               # explicit path

if [[ -n "$1" ]]; then
  issues_dir="${1}"
else
  project_dir="$(git rev-parse --show-toplevel 2>/dev/null || echo "$PWD")"
  project_dir="$(cd "$project_dir" && pwd)"
  issues_dir="$(dirname "$project_dir")/$(basename "$project_dir")-kanban/issues"
fi

issues_dir="$(cd "$issues_dir" 2>/dev/null && pwd)" || {
  echo "[kanban] error: issues directory not found: $issues_dir" >&2
  exit 1
}

project_name="$(basename "$(dirname "$(dirname "$issues_dir")")")"
project_dir="$PWD"
status_dir="/tmp/kanban-${project_name}-$$"
mkdir -p "$status_dir"

python3 ~/projects/renan/agent-tools/scripts/kanban-parse-deps.py "$issues_dir" > "${status_dir}/deps.json"
echo "[kanban] deps parsed → ${status_dir}/deps.json"

ws_ref=$(cmux new-workspace --cwd "$project_dir" \
  --command "KANBAN_MODEL='${KANBAN_MODEL:-sonnet}' KANBAN_HEADLESS='${KANBAN_HEADLESS:-0}' python3 ~/projects/renan/agent-tools/scripts/kanban-orchestrator.py '${issues_dir}' '${project_dir}' '${status_dir}' \$CMUX_WORKSPACE_ID" \
  | awk '{print $2}')
cmux rename-workspace --workspace "$ws_ref" "kanban-${project_name}"
cmux select-workspace --workspace "$ws_ref"
