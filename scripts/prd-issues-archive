#!/usr/bin/env zsh
set -euo pipefail

usage() {
  echo "Usage: prd-issues-archive <planning-dir> <archive-base-dir> [slug]"
  echo ""
  echo "  <planning-dir>     Path to .planning directory (e.g. ~/project-a/.planning)"
  echo "  <archive-base-dir> Root archive folder (e.g. ~/plans-archive)"
  echo "  [slug]             Optional label for the archive subfolder. Derived from"
  echo "                     the PRD title if omitted."
  echo ""
  echo "  Output: <archive-base-dir>/<project>/<YYYY-MM-DD-HH-MM>-<slug>/"
  exit 1
}

[[ $# -lt 2 ]] && usage

planning_dir="${1%/}"
archive_base="${2%/}"
explicit_slug="${3:-}"

# Resolve absolute paths
planning_dir="$(cd "$planning_dir" 2>/dev/null && pwd)" || {
  echo "error: planning directory not found: $1" >&2; exit 1
}
mkdir -p "$archive_base"
archive_base="$(cd "$archive_base" && pwd)"

issues_dir="$planning_dir/issues"

# Collect PRD files — support both old prd.md and new prd-<slug>.md
prd_files=()
if [[ -f "$planning_dir/prd.md" ]]; then
  prd_files+=("$planning_dir/prd.md")
fi
for f in "$planning_dir"/prd-*.md(N); do
  if [[ -f "$f" ]]; then
    prd_files+=("$f")
  fi
done

# Require at least one of prd.md / prd-*.md or issues/
if [[ ${#prd_files[@]} -eq 0 && ! -d "$issues_dir" ]]; then
  echo "error: no prd.md, prd-*.md, or issues/ found in $planning_dir" >&2
  exit 1
fi

# Project name = parent directory of .planning
project_name="$(basename "$(dirname "$planning_dir")")"

# Derive slug — pick the first PRD file for heading extraction
if [[ -n "$explicit_slug" ]]; then
  slug="$explicit_slug"
elif [[ ${#prd_files[@]} -gt 0 ]]; then
  primary_prd="${prd_files[1]}"
  # Extract first non-empty heading, strip leading #/spaces
  raw_heading=$(grep -m1 '^#' "$primary_prd" | sed 's/^#* *//')
  # Slugify: lowercase, replace non-alphanumeric runs with hyphens, trim edges
  slug=$(echo "$raw_heading" \
    | tr '[:upper:]' '[:lower:]' \
    | sed 's/[^a-z0-9]/-/g' \
    | sed 's/--*/-/g' \
    | sed 's/^-//;s/-$//')
  [[ -z "$slug" ]] && slug="planning"
else
  slug="planning"
fi

timestamp=$(date +"%Y-%m-%d-%H-%M")
dest="$archive_base/$project_name/${timestamp}-${slug}"

if [[ -d "$dest" ]]; then
  echo "error: destination already exists: $dest" >&2
  exit 1
fi

mkdir -p "$dest"

copied=0

# Copy all prd-<slug>.md files with their original names
if [[ ${#prd_files[@]} -gt 0 ]]; then
  for f in "${prd_files[@]}"; do
    fname=$(basename "$f")
    cp "$f" "$dest/$fname"
    echo "  $fname"
    (( ++copied )) || true
  done
fi

if [[ -d "$issues_dir" ]]; then
  issue_files=("$issues_dir"/*.md(N))
  if [[ ${#issue_files[@]} -gt 0 ]]; then
    mkdir -p "$dest/issues"
    for f in "${issue_files[@]}"; do
      cp "$f" "$dest/issues/$(basename "$f")"
      echo "  issues/$(basename "$f")"
      (( ++copied )) || true
    done
  fi
fi

echo ""
echo "Archived $copied file(s) → $dest"

# Commit and push the new files in the archive repo
(
  cd "$archive_base"
  git add "$dest"
  git commit -m "archive: ${project_name} ${timestamp}-${slug}"
  git push
)
echo "Committed and pushed to remote."
